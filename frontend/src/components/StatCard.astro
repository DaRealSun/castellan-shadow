---
const { label, value, sublabel } = Astro.props as {
  label: string;
  value: string;
  sublabel?: string;
};
---
<div class="rounded-lg border border-rule bg-white p-5">
  <div class="text-xs font-medium uppercase tracking-wider text-muted">{label}</div>
  <div class="mt-2 font-mono text-2xl text-ink">{value}</div>
  {sublabel && <div class="mt-1 text-xs text-muted">{sublabel}</div>}
</div>
