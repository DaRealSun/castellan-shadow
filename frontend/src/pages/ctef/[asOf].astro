---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FundDashboard from '../../components/FundDashboard.astro';
import { datesFor, snapshotFor } from '../../lib/holdings';

export function getStaticPaths() {
  const dates = datesFor('CTEF');
  // Skip the latest date — that's served by index.astro to avoid a duplicate route.
  return dates.slice(1).map((d) => ({ params: { asOf: d } }));
}

const { asOf } = Astro.params as { asOf: string };
const snap = snapshotFor('CTEF', asOf);
---
<BaseLayout title={`CTEF — ${snap.asOf}`}>
  <FundDashboard ticker="CTEF" snapshot={snap} />
</BaseLayout>
